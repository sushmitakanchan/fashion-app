{
  "mcpServers": {
    "shadcn": {
      "command": "bunx",
      "args": ["shadcn@latest", "mcp"]
    },
    "magicui": {
      "command": "bunx",
      "args": ["-y", "@magicuidesign/mcp@latest"]
    },
    "21st-dev-magic": {
      "command": "bunx",
      "args": ["-y", "@21st-dev/magic@latest"],
      "env": {
        "API_KEY": "${TWENTYFIRST_API_KEY:-}"
      }
    },
    "context7": {
      "command": "bunx",
      "args": ["-y", "@upstash/context7-mcp@latest"]
    }
  }
}
