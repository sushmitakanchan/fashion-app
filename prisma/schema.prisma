// Prisma schema for the Fashion App.
// Docs: https://pris.ly/d/prisma-schema
//
// Prisma 7 uses the `prisma-client` generator (query compiler, no Rust engine)
// and a driver adapter at runtime. The connection URL for the CLI lives in
// `prisma.config.ts`; the runtime connection is provided by the Neon adapter
// in `src/lib/prisma.ts`.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  DELIVERED
  CANCELLED
}

enum Gender {
  MALE
  FEMALE
  UNDISCLOSED
}

/// Standard fashion body-shape taxonomy.
enum BodyType {
  RECTANGLE
  TRIANGLE
  INVERTED_TRIANGLE
  HOURGLASS
  OVAL
}

/// Application user, mirrored from Clerk via `clerkId`.
model User {
  id          String   @id @default(cuid())
  clerkId     String   @unique
  email       String   @unique
  name        String?
  imageUrl    String?
  role        Role     @default(USER)
  orders      Order[]
  favorites   Favorite[]
  auraProfile AuraProfile?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([email])
}

/// Measurements and reference photos used to generate a user's digital twin
/// ("AURA"). One per user — regenerating replaces the existing profile.
model AuraProfile {
  id       String @id @default(cuid())
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId   String @unique
  name     String
  age      Int
  gender   Gender
  // Always metric. The form collects either unit system and converts on submit,
  // so downstream consumers never have to branch on units.
  heightCm Float
  weightKg Float
  bodyType BodyType
  // Cloudinary secure URLs, one per required angle.
  photoFrontUrl   String
  photoLeftUrl    String
  photoRightUrl   String
  photoCloseupUrl String
  photoBackUrl    String
  // Timestamp rather than a boolean: a consent record needs to say when.
  consentedAt DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Category {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Product {
  id          String      @id @default(cuid())
  name        String
  slug        String      @unique
  description String?
  price       Decimal     @db.Decimal(10, 2)
  currency    String      @default("USD")
  images      String[]    @default([])
  sizes       String[]    @default([])
  colors      String[]    @default([])
  stock       Int         @default(0)
  featured    Boolean     @default(false)
  category    Category?   @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  categoryId  String?
  orderItems  OrderItem[]
  favorites   Favorite[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([categoryId])
  @@index([featured])
}

model Order {
  id        String      @id @default(cuid())
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  status    OrderStatus @default(PENDING)
  total     Decimal     @db.Decimal(10, 2)
  items     OrderItem[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@index([userId])
}

model OrderItem {
  id        String  @id @default(cuid())
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId   String
  product   Product @relation(fields: [productId], references: [id])
  productId String
  quantity  Int     @default(1)
  // Unit price captured at purchase time.
  price     Decimal @db.Decimal(10, 2)
  size      String?
  color     String?

  @@index([orderId])
  @@index([productId])
}

model Favorite {
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String
  createdAt DateTime @default(now())

  @@id([userId, productId])
  @@index([productId])
}
