// Prisma schema for AURA.
// Docs: https://pris.ly/d/prisma-schema
//
// Prisma 7 uses the `prisma-client` generator (query compiler, no Rust engine)
// and a driver adapter at runtime. The connection URL for the CLI lives in
// `prisma.config.ts`; the runtime connection is provided by the Neon adapter
// in `src/lib/prisma.ts`.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// Application user, mirrored from Clerk via `clerkId`.
model User {
  id          String   @id @default(cuid())
  clerkId     String   @unique
  email       String   @unique
  name        String?
  imageUrl    String?
  auraProfile AuraProfile?
  savedLooks  SavedLook[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([email])
}

/// Reference photos and consent for one user's AURA portrait profile.
/// Re-saving replaces profile data and references without clearing a portrait.
model AuraProfile {
  id     String @id @default(cuid())
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String @unique
  /// The AURA display name. Owned by AURA, seeded from Google on a first save,
  /// and never written back to the Clerk or Google account it came from.
  name   String
  // Cloudinary secure URLs for the two portrait references.
  photoFrontUrl   String
  photoCloseupUrl String
  // Future 3D-avatar references are optional, but retained if supplied.
  photoLeftUrl    String?
  photoRightUrl   String?
  photoBackUrl    String?
  // Saved only by the separate portrait-generation operation.
  portraitUrl     String?
  // Timestamp rather than a boolean: a consent record needs to say when.
  consentedAt DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

/// One durably saved try-on: the generated look, the Source(s) it was built
/// from, an auto-derived caption, and a snapshot of the AURA portrait it was
/// generated against. Belongs to one user; a user has many. Insert-only and
/// immutable once saved — the absence of an `updatedAt` column encodes that.
model SavedLook {
  id     String @id @default(cuid())
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String
  /// Cloudinary secure URL of the generated look.
  lookImageUrl String
  /// Auto-derived from source/garment names; no manual rename in v1.
  caption      String
  /// Snapshot of `AuraProfile.portraitUrl` at save time, so the record stays
  /// faithful even after the participant later regenerates their portrait.
  portraitUrl  String
  /// Array of SavedLookSource (see `@/lib/validations`). The database does NOT
  /// validate this JSON — it MUST be Zod-guarded at write time.
  sources      Json
  createdAt    DateTime @default(now())

  @@index([userId, createdAt]) // newest-first per-owner grid
}
