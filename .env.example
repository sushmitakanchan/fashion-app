# ---------------------------------------------------------------------------
# AURA — environment variables
#
# Copy this file to `.env` and fill in the values:
#   cp .env.example .env
#
# `.env` is read by BOTH Next.js and the Prisma CLI (Bun auto-loads it too),
# and is gitignored. Never commit real secrets.
# ---------------------------------------------------------------------------

# --- Database (Neon Postgres) ----------------------------------------------
# Neon dashboard → Connection string. Use the POOLED connection string.
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/dbname?sslmode=require"

# --- Clerk (authentication) ------------------------------------------------
# https://dashboard.clerk.com → API keys.
# Tip: leave BOTH blank in development to use Clerk's keyless mode, which
# auto-provisions a temporary dev instance on first run.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Optional route overrides (uncomment once you add these pages):
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
# NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
#
# AURA pilot identity policy (configured in the Clerk Dashboard, not via env):
# User & authentication → disable every sign-in/sign-up factor except the
# Google SSO connection; SSO connections → enable Google for both sign-in and
# sign-up. The app's "Continue with Google" button is intentionally the only
# entry point, and its server routes independently enforce this policy.

# --- AI provider selection -------------------------------------------------
# Which provider serves text generation: openai | anthropic.
# Leave blank for openai. The selected provider's key below must be set —
# there is no fallback to the other provider.
AI_PROVIDER=

# --- OpenAI ----------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Anthropic (optional) --------------------------------------------------
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# --- Cloudinary (media storage) --------------------------------------------
# https://console.cloudinary.com → Dashboard.
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
